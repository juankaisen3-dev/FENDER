{
  "name": "fender-downloader",
  "version": "2.0.0",
  "description": "Application de téléchargement vidéo premium - Architecture Pro",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:frontend": "cd fender && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd fender && npm install && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "path": "^0.12.7",
    "youtube-dl-exec": "^3.1.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
